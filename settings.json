{
  "permissions": {
    "allow": [
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(jq *)",
      "Bash(python3 -c*)",
      "Bash(node --version*)",
      "Bash(npm list*)",
      "Bash(npm audit*)",
      "Bash(gh auth status*)",
      "Bash(gh repo view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue list*)",
      "Bash(git *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/bin/guard-sensitive-files.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Waiting for your input' --icon=dialog-information --expire-time=8000 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Permission requested — check terminal' --icon=dialog-warning --urgency=critical --expire-time=0 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "wordpress.com@claude-plugins-official": true,
    "desktop-commander@claude-plugins-official": true,
    "exa@claude-plugins-official": true,
    "knowledge-catalog@claude-plugins-official": true
  },
  "theme": "dark",
  "mcpServers": {
    "token-optimizer": {
      "command": "token-optimizer-mcp",
      "args": []
    },
    "github": {
      "command": "/home/user/.claude/bin/mcp-github",
      "args": []
    },
    "memory": {
      "command": "mcp-server-memory",
      "args": []
    }
  }
}
